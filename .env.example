# --- Inventory Service ---
INVENTORY_DATABASE_URL=postgresql://username:password@host:port/db_name
INVENTORY_HOST=0.0.0.0
INVENTORY_IP=0.0.0.0
INVENTORY_PORT=8080

# --- Billing Service ---
BILLING_DATABASE_URL=postgresql://username:password@host:port/db_name
BILLING_HOST=0.0.0.0

# --- API Gateway ---
API_GATEWAY_PORT=8081
API_GATEWAY_HOST=0.0.0.0

# --- RabbitMQ ---
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASS=your_rabbitmq_password
RABBITMQ_VHOST=/
RABBITMQ_HOST=0.0.0.0
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=billing_queue

# --- Database ---
USER_DB=your_db_user
PASSWORD_DB=your_db_password